{
  "name": "@workspace/harness-flow",
  "version": "0.1.0",
  "description": "HarnessFlow CLI — A harness layer between users and AI coding agents (Claude CLI, Codex, etc.)",
  "private": true,
  "type": "module",
  "bin": {
    "harness": "./bin/harness.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node build.mjs",
    "start": "node dist/index.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:e2e": "node scripts/e2e-test.mjs",
    "lint": "eslint src/"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "js-yaml": "^4.1.0",
    "zod": "catalog:",
    "execa": "^9.3.0",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/js-yaml": "^4.0.9",
    "tsx": "^4.19.0",
    "esbuild": "^0.27.3",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "ts-jest": "^29.2.5"
  }
}
